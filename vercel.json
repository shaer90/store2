{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/(.*\\.(js|css|jsx|json|svg|png|jpg|ico|txt|webmanifest))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
